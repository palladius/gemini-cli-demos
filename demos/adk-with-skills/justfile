export UV_INDEX_URL := "https://pypi.org/simple"

# List available commands
list:
    just -l

# Set up the environment
setup:
    uv venv
    uv pip install google-adk

# Test 1: Basic LLM API test
test-api:
    echo "How are you?" | uv run adk run banana_ric_agent/

# Test 2: Skill check (help command)
test-skill:
    echo "Run the Nanobanana python script with --help and show me the options for image size" | uv run adk run banana_ric_agent/

# Test 3: Image generation
test-image:
    #!/bin/bash
    export UV_INDEX_URL="https://pypi.org/simple"
    echo "Create an image of Riccardo eating an Avocado with an ADK label on it. Name the file riccardo_avocado_attach.png" | uv run adk run banana_ric_agent/

# Test 4: Deprecated image generation
test-deprecated-image:
    source .venv/bin/activate && python3 -c "from banana_ric_agent.tools import generate_riccardo_image; print(generate_riccardo_image('Riccardo eating an Avocado with an ADK label on it', 'riccardo_avocado_deprecated.png'))"

# Run interactive session
run:
    uv run adk run banana_ric_agent/

# Start web UI
web:
    export OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT="true"
    uv run adk web --adk_app_object=app banana_ric_agent/

# Deploy to GEAP (Agent Engine)
deploy:
    #!/bin/bash
    PROJECT="palladius-genai"
    REGION="us-central1"
    DISPLAY_NAME="banana_ric_agent"
    
    # Try to find existing agent ID
    AGENT_ID=$(uv run python bin/find_agent_id.py "$PROJECT" "$REGION" "$DISPLAY_NAME" 2>/dev/null || echo "")
    
    if [ -n "$AGENT_ID" ]; then
        echo "Updating existing agent with ID: $AGENT_ID"
        uv run adk deploy agent_engine \
            --project="$PROJECT" \
            --region="$REGION" \
            --display_name="$DISPLAY_NAME" \
            --agent_engine_id="$AGENT_ID" \
            --adk_app_object=app \
            --otel_to_cloud \
            banana_ric_agent/
    else
        echo "Creating new agent instance..."
        uv run adk deploy agent_engine \
            --project="$PROJECT" \
            --region="$REGION" \
            --display_name="$DISPLAY_NAME" \
            --adk_app_object=app \
            --otel_to_cloud \
            banana_ric_agent/
    fi

# Deploy Hello Agent
deploy-hello:
    uv run adk deploy agent_engine \
        --project="palladius-genai" \
        --region="us-central1" \
        --display_name="hello_agent" \
        --adk_app_object=app \
        hello_agent/

clean:
    rm -rf out/
    rm -rf .venv/
